---
import { Image } from 'astro:assets';
import { getImages } from '../data/imageStore';

const images = (await getImages())
	.slice()
	.sort(() => Math.random() - 0.5)
	.slice(0, 3);
const year = new Date().getFullYear();
---

<div class="w-full">
	<div class="mb-12 px-4 md:px-8 lg:px-12 text-center">
		<h2 class="text-3xl md:text-4xl font-bold">Recent Works</h2>
	</div>

	<div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 px-4 md:px-8 lg:px-12">
		{
			images.map((image) => (
				<article class="group">
					<div class="overflow-hidden bg-gray-100">
						<Image
							src={image.src}
							quality={90}
							format="webp"
							sizes="(max-width: 768px) 100vw, 33vw"
							widths={[320, 480, 640, 800, 1000]}
							width={image.src.width}
							height={image.src.height}
							class="w-full aspect-[4/5] object-cover transition-transform duration-1000 group-hover:scale-[1.02]"
							alt={image.title}
						/>
					</div>
					<div class="pt-3 text-[18px] about-readable text-gray-600 flex items-center justify-between">
						<span class="font-normal">Placeholder text</span>
						<span class="font-normal">{year}</span>
					</div>
				</article>
			))
		}
	</div>
</div>
