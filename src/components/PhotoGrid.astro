---
import 'glightbox/dist/css/glightbox.css';
import '../styles/glightbox-custom.css';
import { Image } from 'astro:assets';
import type { Image as ImageType } from '../data/galleryData';

interface Props {
	images: ImageType[];
}

const { images } = Astro.props;
---

<section id="photo-grid" class="relative w-full mx-auto overflow-hidden">
	{
		images.map((image) => (
			<a
				href={image.src.src}
				class="photo-item glightbox absolute transition-transform duration-1000 hover:scale-[1.02] hover:z-10"
				data-gallery="gallery1"
				data-type="image"
				data-glightbox={image.description ? `title: ${image.description}` : undefined}
			>
				<Image
					src={image.src}
					quality={85}
					format="webp"
					sizes="(max-width: 640px) 92vw, (max-width: 900px) 46vw, (max-width: 1280px) 31vw, (max-width: 1680px) 24vw, 380px"
					widths={[160, 220, 280, 340, 420, 520, 640, 760]}
					loading="lazy"
					fetchpriority="auto"
					width={image.src.width}
					height={image.src.height}
					class="w-full h-full object-cover rounded-sm shadow-sm hover:shadow-lg transition-shadow duration-1000"
					alt={image.title}
				/>
			</a>
		))
	}
</section>

<script>
	import '../scripts/photo-grid';
</script>
